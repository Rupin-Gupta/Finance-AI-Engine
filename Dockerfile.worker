FROM python:3.12-slim
WORKDIR /app

COPY requirements-worker.txt requirements-api.txt ./
RUN pip install --no-cache-dir -r requirements-worker.txt

# Pre-download FinBERT model at build time so runtime cold-start is instant
RUN python -c "\
from transformers import pipeline; \
pipeline('text-classification', model='ProsusAI/finbert', device=-1)"

COPY backend/ backend/

CMD ["python", "-m", "backend.scheduler"]
