# Database — change POSTGRES_PASSWORD before deploying
POSTGRES_PASSWORD=change-me-before-deploy
DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@db:5432/finance

# Auth — change before deploying
API_KEY=changeme-replace-in-production

# LLM — set exactly one provider
LLM_PROVIDER=gemini          # "gemini" or "openai"
OPENAI_API_KEY=
GEMINI_API_KEY=
LLM_MODEL=gemini-1.5-flash   # or gpt-4o-mini for openai

# Embeddings (do not change without rebuilding FAISS index)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Market data
FINNHUB_API_KEY=

# FAISS index paths (relative to /app inside containers)
FAISS_INDEX_PATH=data/faiss.index
FAISS_METADATA_PATH=data/faiss_meta.pkl

# Scheduler cron expressions (standard 5-field cron)
MARKET_REFRESH_CRON=0 18 * * 1-5
ANALYTICS_REFRESH_CRON=0 * * * 1-5
ANOMALY_SCAN_CRON=30 * * * 1-5
DOC_REFRESH_CRON=0 2 * * 0
REPORT_REFRESH_CRON=0 19 * * 1-5
SENTIMENT_REFRESH_CRON=0 8 * * 1-5
DECISION_REFRESH_CRON=30 8 * * 1-5

# Tracked stock symbols (comma-separated, no spaces)
TRACKED_SYMBOLS=AAPL,MSFT,GOOGL,AMZN,TSLA

# CORS — restrict to your actual frontend origin(s) in production
# Example: CORS_ORIGINS=https://app.yourdomain.com,https://dash.yourdomain.com
CORS_ORIGINS=*

# Streamlit → API URL (inside Docker network)
API_BASE_URL=http://api:8000
